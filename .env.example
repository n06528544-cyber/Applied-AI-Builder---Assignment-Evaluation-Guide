# Copy to .env and fill in to enable the optional LLM extractor.
# The deterministic (no-key) extractor is used when this is left empty.

DDR_LLM_API_KEY=
# llm provider: openai | anthropic | ollama
DDR_LLM_PROVIDER=none
DDR_LLM_MODEL=gpt-4o-mini
# for Ollama / proxies:
# DDR_LLM_BASE_URL=http://localhost:11434/v1
